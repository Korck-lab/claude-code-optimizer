#!/bin/bash
# cc-optimizer version bump — atomically bump patch version across 4 files.
#
# Skip rule (amend/no-op guard):
#   The bump only runs when there is a STAGED DELTA vs HEAD in the root
#   (excluding .githooks/, VERSION, and docs-only changes).
#   This covers both:
#     * nothing relevant staged at all, and
#     * `git commit --amend` with identical content — a no-op amend must NOT re-bump.
#   An amend that stages NEW code changes DOES re-bump: the sequence
#   stays monotonic (reused version numbers are forbidden by design).
#   On an unborn branch, the diff base is the empty tree.
#
# Atomicity (scope: REPO files only):
#   Everything is computed and validated BEFORE anything is written. If any
#   write fails mid-way, an ERR trap restores the original bytes (no partial
#   bump, no phantom version). The files are then re-staged.
set -Eeuo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$REPO_ROOT/VERSION"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
MARKETPLACE_JSON="$REPO_ROOT/.claude-plugin/marketplace.json"
PYPROJECT_TOML="$REPO_ROOT/pyproject.toml"
INIT_PY="$REPO_ROOT/optimizer/__init__.py"

# --- Skip guard: detect staged deltas outside docs and version file ---
if git -C "$REPO_ROOT" rev-parse --verify --quiet HEAD >/dev/null 2>&1; then
  base_ref="HEAD"
else
  base_ref="$(git -C "$REPO_ROOT" hash-object -t tree /dev/null)"
fi

# Check if there are staged changes excluding .githooks, VERSION, and .md files
staged=$(git -C "$REPO_ROOT" diff --cached --name-only "$base_ref" -- || true)
relevant_staged=$(echo "$staged" | grep -v -E '^\.githooks/|^VERSION$|\.md$|^\.gitignore$|^\.git' || true)

if [ -z "$relevant_staged" ]; then
  exit 0
fi

# --- Phase 1: read + validate inputs (nothing written yet) ---
for f in "$VERSION_FILE" "$PLUGIN_JSON" "$MARKETPLACE_JSON" "$PYPROJECT_TOML" "$INIT_PY"; do
  if [ ! -f "$f" ]; then
    echo "ERROR: required file not found: $f" >&2
    exit 1
  fi
done

current=$(tr -d '[:space:]' < "$VERSION_FILE")

if ! printf '%s' "$current" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  echo "ERROR: Invalid semver format '${current}' in VERSION file" >&2
  exit 1
fi

IFS='.' read -r major minor patch <<< "$current"
new_patch=$((patch + 1))
new_version="${major}.${minor}.${new_patch}"

# --- Phase 2: backup originals + arm rollback ---
backup_dir="$(mktemp -d)"
cp "$VERSION_FILE" "$backup_dir/VERSION"
cp "$PLUGIN_JSON" "$backup_dir/plugin.json"
cp "$MARKETPLACE_JSON" "$backup_dir/marketplace.json"
cp "$PYPROJECT_TOML" "$backup_dir/pyproject.toml"
cp "$INIT_PY" "$backup_dir/__init__.py"

rollback() {
  cp "$backup_dir/VERSION" "$VERSION_FILE" 2>/dev/null || true
  cp "$backup_dir/plugin.json" "$PLUGIN_JSON" 2>/dev/null || true
  cp "$backup_dir/marketplace.json" "$MARKETPLACE_JSON" 2>/dev/null || true
  cp "$backup_dir/pyproject.toml" "$PYPROJECT_TOML" 2>/dev/null || true
  cp "$backup_dir/__init__.py" "$INIT_PY" 2>/dev/null || true
  rm -rf "$backup_dir"
  echo "ERROR: version bump failed; original file contents restored (no partial bump)" >&2
}
trap rollback ERR

# --- Phase 3: compute + validate ALL new contents, then write ---
python3 - "$VERSION_FILE" "$PLUGIN_JSON" "$MARKETPLACE_JSON" "$PYPROJECT_TOML" "$INIT_PY" "$current" "$new_version" <<'PY'
import json, re, sys

version_path, plugin_path, marketplace_path, pyproject_path, init_path, current, new_version = sys.argv[1:8]

def die(msg):
    sys.stderr.write("ERROR: %s\n" % msg)
    sys.exit(1)

originals = {}
for path in (version_path, plugin_path, marketplace_path, pyproject_path, init_path):
    try:
        with open(path) as fh:
            originals[path] = fh.read()
    except OSError as exc:
        die("cannot read %s: %s" % (path, exc))

# 1. plugin.json: must be valid JSON and contain the old version
try:
    json.loads(originals[plugin_path])
except ValueError as exc:
    die("%s is not valid JSON: %s" % (plugin_path, exc))
pattern = re.compile(r'("version"\s*:\s*)"%s"' % re.escape(current))
new_plugin, count = pattern.subn(
    lambda m: m.group(1) + '"%s"' % new_version, originals[plugin_path], count=1
)
if count != 1:
    die(
        '%s does not contain "version": "%s" (drifted from VERSION); '
        "refusing silent no-op" % (plugin_path, current)
    )
json.loads(new_plugin)  # sanity check

# 2. marketplace.json: must be valid JSON with claude-code-optimizer entry
try:
    marketplace = json.loads(originals[marketplace_path])
except ValueError as exc:
    die("%s is not valid JSON: %s" % (marketplace_path, exc))
entries = [
    e for e in marketplace.get("plugins", [])
    if isinstance(e, dict) and e.get("name") == "claude-code-optimizer"
]
if not entries:
    die("%s has no 'claude-code-optimizer' plugin entry" % marketplace_path)
for entry in entries:
    entry["version"] = new_version
new_marketplace = json.dumps(marketplace, indent=2, ensure_ascii=False) + "\n"

# 3. pyproject.toml: replace version = "x.y.z"
pattern = re.compile(r'(version\s*=\s*)"%s"' % re.escape(current))
new_pyproject, count = pattern.subn(
    lambda m: m.group(1) + '"%s"' % new_version, originals[pyproject_path], count=1
)
if count != 1:
    die(
        '%s does not contain version = "%s" (drifted from VERSION); '
        "refusing silent no-op" % (pyproject_path, current)
    )

# 4. optimizer/__init__.py: replace __version__ = "x.y.z"
pattern = re.compile(r'(__version__\s*=\s*)"%s"' % re.escape(current))
new_init, count = pattern.subn(
    lambda m: m.group(1) + '"%s"' % new_version, originals[init_path], count=1
)
if count != 1:
    die(
        '%s does not contain __version__ = "%s" (drifted from VERSION); '
        "refusing silent no-op" % (init_path, current)
    )

# Everything validated — write the five files
for path, content in (
    (version_path, new_version + "\n"),
    (plugin_path, new_plugin),
    (marketplace_path, new_marketplace),
    (pyproject_path, new_pyproject),
    (init_path, new_init),
):
    try:
        with open(path, "w") as fh:
            fh.write(content)
    except OSError as exc:
        die("write failed for %s: %s" % (path, exc))
PY

# --- Phase 4: stage the bumped files (still under ERR trap) ---
git -C "$REPO_ROOT" add -- "$VERSION_FILE" "$PLUGIN_JSON" "$MARKETPLACE_JSON" "$PYPROJECT_TOML" "$INIT_PY"

trap - ERR
rm -rf "$backup_dir"

echo "Bumped version: ${current} -> ${new_version}"
